    int N;
    scanf("%d", &N);

    for (int i = 0; i < N; i++) {
        char op[10];
        scanf("%s", op);

        if (op[0] == 'i') { // insert
            int x;
            scanf("%d", &x);
            insert(x);
        } else if (op[0] == 'd') { // delete
            delete();
        } else if (op[0] == 'p') { // peek
            peek();
        }
    }

    return 0;
}


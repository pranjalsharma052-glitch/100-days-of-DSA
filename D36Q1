    newNode->data = value;

    if (q->rear == NULL) {
        q->front = q->rear = newNode;
        newNode->next = newNode; // circular link
        return;
    }

    newNode->next = q->front;
    q->rear->next = newNode;
    q->rear = newNode;
}

